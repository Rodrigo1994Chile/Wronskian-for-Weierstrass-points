A.<p>=PolynomialRing(QQ)
A=Frac(A)
T.<k>=PolynomialRing(A)
C=k^4+p*k^2+1

K.<k>=T.quotient(C)

R.<x,y,z>=PolynomialRing(K)
F = x^4+y^4+z^4+p*(x^2*y^2+y^2*z^2+z^2*x^2)

M=Wronskian(F,(0,k),[],4)


detM=M.det()

f=detM[0]
f=f*f[0].denominator()

R.<k,p>=PolynomialRing(QQ,order="lex")
I=Ideal([R(f),R(C)])
GB=I.groebner_basis()

h=GB[-1]
for poli in factor(h):
    print(poli)
