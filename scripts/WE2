A.<p>=PolynomialRing(QQ)
A=Frac(A)
T.<k>=PolynomialRing(A)
C=k^2 + 3

K.<k>=T.quotient(C)

R.<x,y,z>=PolynomialRing(K)

F = F = x^6+y^6+z^6+(x^2+y^2+z^2)*(x^4+y^4+z^4)-12*x^2*y^2*z^2-p*(x^2-y^2)*(y^2-z^2)*(z^2-x^2)

M=Wronskian(F,(1,k),[],5)

detM=M.det()

#f=detM[1]
f=detM[0]
f=f*f[0].denominator()


R.<k,p>=PolynomialRing(QQ,order="lex")

I=Ideal([R(f),R(C)])
GB=I.groebner_basis()

h=GB[-1]
for poli in factor(h):
    print(poli)


#### Output:
#  (p^2 - 105, 1)
#  (p^2 + 3, 3)

